@3000       // Start at address 0x3000
3E 1C       // MVI A, 0x1C     ; Ink color (Bright Green)
32 01 C0    // STA 0xC001
3E 00       // MVI A, 0x00     ; Background color (Black)
32 02 C0    // STA 0xC002
3E 00       // MVI A, 0
32 5E 31    // STA VAR_X
3E 64       // MVI A, 100      ; Radius = 100
32 5F 31    // STA VAR_Y
21 9D FF    // LXI H, 0xFF9D   ; Initial D = 1 - R = -99 = 0xFF9D
22 60 31    // SHLD VAR_D
3A 5E 31    // LDA VAR_X
47          // MOV B, A
3A 5F 31    // LDA VAR_Y
B8          // CMP B
DA 73 30    // JC LOOP_END     ; If Y < X, we are done drawing
CD 74 30    // CALL DRAW_8
2A 60 31    // LHLD VAR_D
7C          // MOV A, H
B7          // ORA A
FA 59 30    // JM D_LESS_THAN_ZERO
3A 5E 31    // LDA VAR_X
47          // MOV B, A
3A 5F 31    // LDA VAR_Y
4F          // MOV C, A
78          // MOV A, B
91          // SUB C           ; A = x - y
5F          // MOV E, A
07          // RLC
9F          // SBB A
57          // MOV D, A        ; DE = x - y (16-bit signed)
EB          // XCHG            ; HL = x - y, DE = d
29          // DAD H           ; HL = 2 * (x - y)
01 05 00    // LXI B, 5
09          // DAD B           ; HL = 2 * (x - y) + 5
19          // DAD D           ; HL = d + 2 * (x - y) + 5
22 60 31    // SHLD VAR_D
3A 5E 31    // LDA VAR_X
3C          // INR A
32 5E 31    // STA VAR_X
3A 5F 31    // LDA VAR_Y
3D          // DCR A
32 5F 31    // STA VAR_Y
C3 70 30    // JMP LOOP_NEXT
3A 5E 31    // LDA VAR_X
5F          // MOV E, A
16 00       // MVI D, 0
EB          // XCHG            ; HL = x, DE = d
29          // DAD H           ; HL = 2 * x
01 03 00    // LXI B, 3
09          // DAD B           ; HL = 2 * x + 3
19          // DAD D           ; HL = d + 2 * x + 3
22 60 31    // SHLD VAR_D
3A 5E 31    // LDA VAR_X
3C          // INR A
32 5E 31    // STA VAR_X
C3 1A 30    // JMP LOOP_START
C9          // RET             ; Return to monitor gracefully
3A 5E 31    // LDA VAR_X
5F          // MOV E, A
16 00       // MVI D, 0
21 A0 00    // LXI H, 160      ; xc = 160
19          // DAD D
44          // MOV B, H
4D          // MOV C, L        ; BC = xc + x
3A 5F 31    // LDA VAR_Y
C6 78       // ADI 120         ; yc = 120
5F          // MOV E, A        ; E = yc + y
CD 21 31    // CALL DRAW_PIXEL
3A 5E 31    // LDA VAR_X
5F          // MOV E, A
3E A0       // MVI A, 160
93          // SUB E
4F          // MOV C, A
3E 00       // MVI A, 0
9A          // SBB D
47          // MOV B, A        ; BC = 160 - x
3A 5F 31    // LDA VAR_Y
C6 78       // ADI 120
5F          // MOV E, A
CD 21 31    // CALL DRAW_PIXEL
3A 5E 31    // LDA VAR_X
5F          // MOV E, A
16 00       // MVI D, 0
21 A0 00    // LXI H, 160
19          // DAD D
44          // MOV B, H
4D          // MOV C, L        ; BC = xc + x
3E 78       // MVI A, 120
21 5F 31    // LXI H, VAR_Y
96          // SUB M
5F          // MOV E, A        ; E = 120 - y
CD 21 31    // CALL DRAW_PIXEL
3A 5E 31    // LDA VAR_X
5F          // MOV E, A
3E A0       // MVI A, 160
93          // SUB E
4F          // MOV C, A
3E 00       // MVI A, 0
9A          // SBB D
47          // MOV B, A        ; BC = 160 - x
3E 78       // MVI A, 120
21 5F 31    // LXI H, VAR_Y
96          // SUB M
5F          // MOV E, A        ; E = 120 - y
CD 21 31    // CALL DRAW_PIXEL
3A 5F 31    // LDA VAR_Y
5F          // MOV E, A
16 00       // MVI D, 0
21 A0 00    // LXI H, 160
19          // DAD D
44          // MOV B, H
4D          // MOV C, L        ; BC = xc + y
3A 5E 31    // LDA VAR_X
C6 78       // ADI 120
5F          // MOV E, A        ; E = yc + x
CD 21 31    // CALL DRAW_PIXEL
3A 5F 31    // LDA VAR_Y
5F          // MOV E, A
3E A0       // MVI A, 160
93          // SUB E
4F          // MOV C, A
3E 00       // MVI A, 0
9A          // SBB D
47          // MOV B, A        ; BC = 160 - y
3A 5E 31    // LDA VAR_X
C6 78       // ADI 120
5F          // MOV E, A        ; E = yc + x
CD 21 31    // CALL DRAW_PIXEL
3A 5F 31    // LDA VAR_Y
5F          // MOV E, A
16 00       // MVI D, 0
21 A0 00    // LXI H, 160
19          // DAD D
44          // MOV B, H
4D          // MOV C, L        ; BC = xc + y
3E 78       // MVI A, 120
21 5E 31    // LXI H, VAR_X
96          // SUB M
5F          // MOV E, A        ; E = 120 - x
CD 21 31    // CALL DRAW_PIXEL
3A 5F 31    // LDA VAR_Y
5F          // MOV E, A
3E A0       // MVI A, 160
93          // SUB E
4F          // MOV C, A
3E 00       // MVI A, 0
9A          // SBB D
47          // MOV B, A        ; BC = 160 - y
3E 78       // MVI A, 120
21 5E 31    // LXI H, VAR_X
96          // SUB M
5F          // MOV E, A        ; E = 120 - x
CD 21 31    // CALL DRAW_PIXEL
C9          // RET
E5          // PUSH H
D5          // PUSH D
C5          // PUSH B
F5          // PUSH PSW
6B          // MOV L, E
26 00       // MVI H, 0
29          // DAD H           ; HL = Y * 2
29          // DAD H           ; HL = Y * 4
29          // DAD H           ; HL = Y * 8
54          // MOV D, H
5D          // MOV E, L        ; DE = Y * 8
29          // DAD H           ; HL = Y * 16
29          // DAD H           ; HL = Y * 32
19          // DAD D           ; HL = Y * 40
78          // MOV A, B
0F          // RRC
0F          // RRC
0F          // RRC
E6 E0       // ANI 0xE0
57          // MOV D, A
79          // MOV A, C
0F          // RRC
0F          // RRC
0F          // RRC
E6 1F       // ANI 0x1F
B2          // ORA D
85          // ADD L
6F          // MOV L, A
7C          // MOV A, H
CE 40       // ACI 0x40        ; Add VRAM Base address (0x4000)
67          // MOV H, A        ; HL now points directly to the VRAM byte
79          // MOV A, C
E6 07       // ANI 0x07        ; A = X % 8
CA 55 31    // JZ MASK_DONE_FAST
57          // MOV D, A        ; Loop counter
3E 80       // MVI A, 0x80
0F          // RRC
15          // DCR D
C2 4D 31    // JNZ MASK_LOOP
C3 57 31    // JMP APPLY_MASK
3E 80       // MVI A, 0x80
B6          // ORA M           ; Read from VRAM, OR with bit mask
77          // MOV M, A        ; Write back to VRAM
F1          // POP PSW
C1          // POP B
D1          // POP D
E1          // POP H
C9          // RET
