D2 E3 00    // JNC RL_LOOP
47          // MOV B, A            ; Save character
3A 05 20    // LDA VAR_INPUT_LEN
FE 3C       // CPI 60
D2 E3 00    // JNC RL_LOOP         ; If full, ignore
5F          // MOV E, A            ; E = length
