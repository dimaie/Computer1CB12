C3 3A 01    // JMP GK_WAIT
47          // MOV B, A            ; Save scan code
3A 04 20    // LDA VAR_KB_STATE
B7          // ORA A
CA 65 01    // JZ GK_DECODE        ; If state is 0, normal MAKE code
3E 00       // MVI A, 0
32 04 20    // STA VAR_KB_STATE
C3 3A 01    // JMP GK_WAIT
78          // MOV A, B            ; Restore scan code
FE 80       // CPI 0x80            ; Ensure it's < 128 to prevent table overflow
D2 3A 01    // JNC GK_WAIT
21 A9 02    // LXI H, SCAN_TO_ASCII
5F          // MOV E, A
16 00       // MVI D, 0
19          // DAD D               ; HL = SCAN_TO_ASCII + Scan Code
7E          // MOV A, M            ; Load ASCII value
B7          // ORA A               ; Is it mapped to 0 (unknown)?
CA 3A 01    // JZ GK_WAIT
C9          // RET                 ; Valid ASCII in A!
F5          // PUSH PSW
3E 20       // MVI A, ' '
