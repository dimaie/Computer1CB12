CD DE 00    // CALL READ_LINE
3A 05 20    // LDA VAR_INPUT_LEN
B7          // ORA A
CA 31 00    // JZ MAIN_LOOP        ; Empty input, return to prompt
21 06 20    // LXI H, VAR_INPUT_BUF
CD 9E 01    // CALL SKIP_SPACES
CD A6 01    // CALL PARSE_HEX_BYTE
DA 31 00    // JC MAIN_LOOP        ; If invalid hex, return to prompt
47          // MOV B, A
2A 46 20    // LHLD VAR_MODIFY_PTR
70          // MOV M, B
23          // INX H
22 46 20    // SHLD VAR_MODIFY_PTR
C3 A3 00    // JMP MODIFY_PROMPT
3E 00       // MVI A, 0
