21 06 20    // LXI H, VAR_INPUT_BUF
19          // DAD D
36 00       // MVI M, 0
CD 6A 02    // CALL NEW_LINE
C9          // RET
DB 01       // IN 0x01
E6 01       // ANI 0x01
CA 3A 01    // JZ GK_WAIT
DB 00       // IN 0x00
FE E0       // CPI 0xE0            ; Ignore extended prefix
CA 3A 01    // JZ GK_WAIT
FE F0       // CPI 0xF0            ; Is it a Break code?
C2 55 01    // JNZ GK_CHECK_STATE
3E 01       // MVI A, 1
